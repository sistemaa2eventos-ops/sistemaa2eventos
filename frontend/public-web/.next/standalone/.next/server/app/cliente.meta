{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/cliente/layout,_N_T_/cliente/page,_N_T_/cliente"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/cliente/__PAGE__",
    "/cliente",
    "/_index",
    "/_head"
  ]
}